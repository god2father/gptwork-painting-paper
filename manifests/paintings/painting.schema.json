{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "painting.schema.json",
  "type": "object",
  "required": ["id", "title", "subtitle", "duration", "canvas", "background", "environment", "camera", "chapters", "layers"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string", "minLength": 1 },
    "duration": { "type": "number", "exclusiveMinimum": 0 },
    "canvas": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "background": {
      "type": "object",
      "required": ["src", "alt"],
      "properties": {
        "src": { "type": "string", "minLength": 1 },
        "alt": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "object",
      "required": ["workspace"],
      "properties": { "workspace": { "$ref": "#/$defs/asset" } },
      "additionalProperties": false
    },
    "camera": {
      "type": "object",
      "required": ["collapsed", "focused"],
      "properties": {
        "collapsed": { "$ref": "#/$defs/transform" },
        "focused": { "$ref": "#/$defs/transform" }
      },
      "additionalProperties": false
    },
    "chapters": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/chapter" }
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/layer" }
    }
  },
  "$defs": {
    "asset": {
      "type": "object",
      "required": ["src", "alt"],
      "properties": {
        "src": { "type": "string", "minLength": 1 },
        "alt": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "chapter": {
      "type": "object",
      "required": ["id", "start", "end"],
      "properties": {
        "id": { "enum": ["reveal", "arrival", "focus", "layers", "observe"] },
        "start": { "type": "number", "minimum": 0, "maximum": 1 },
        "end": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "transform": {
      "type": "object",
      "required": ["x", "y", "z", "scale", "rotation", "opacity"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" },
        "scale": { "type": "number", "exclusiveMinimum": 0 },
        "rotation": { "type": "number" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "layer": {
      "type": "object",
      "required": ["id", "name", "src", "alt", "description", "z", "shadow", "selection3d", "assembly", "bounds", "collapsed", "expanded", "animation", "parallax"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "src": { "type": "string", "minLength": 1 },
        "alt": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "z": { "type": "number" },
        "shadow": { "type": "number", "minimum": 0, "maximum": 1 },
        "selection3d": {
          "type": "object",
          "required": ["z", "rotateX", "rotateY", "scale"],
          "properties": {
            "z": { "type": "number", "exclusiveMinimum": 0 },
            "rotateX": { "type": "number", "minimum": -14, "maximum": 14 },
            "rotateY": { "type": "number", "minimum": -14, "maximum": 14 },
            "scale": { "type": "number", "exclusiveMinimum": 0 }
          },
          "additionalProperties": false
        },
        "assembly": {
          "type": "object",
          "required": ["start", "duration", "from", "via", "ease"],
          "properties": {
            "start": { "type": "number", "minimum": 0 },
            "duration": { "type": "number", "exclusiveMinimum": 0 },
            "from": {
              "type": "object",
              "required": ["x", "y", "rotation", "scale"],
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" },
                "rotation": { "type": "number" },
                "scale": { "type": "number", "exclusiveMinimum": 0 }
              },
              "additionalProperties": false
            },
            "via": {
              "type": "object",
              "required": ["x", "y"],
              "properties": { "x": { "type": "number" }, "y": { "type": "number" } },
              "additionalProperties": false
            },
            "ease": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "bounds": {
          "type": "object",
          "required": ["x", "y", "width", "height"],
          "properties": {
            "x": { "type": "number", "minimum": 0 },
            "y": { "type": "number", "minimum": 0 },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 }
          },
          "additionalProperties": false
        },
        "collapsed": { "$ref": "#/$defs/transform" },
        "expanded": { "$ref": "#/$defs/transform" },
        "animation": {
          "type": "object",
          "required": ["start", "duration", "ease"],
          "properties": {
            "start": { "type": "number", "minimum": 0, "maximum": 1 },
            "duration": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
            "ease": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "parallax": {
          "type": "object",
          "required": ["x", "y"],
          "properties": { "x": { "type": "number" }, "y": { "type": "number" } },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
