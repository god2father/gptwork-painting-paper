{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reference video timeline analysis",
  "type": "object",
  "required": [
    "media",
    "scenes"
  ],
  "properties": {
    "media": {
      "type": "object",
      "required": [
        "duration",
        "width",
        "height",
        "fps"
      ],
      "properties": {
        "duration": {
          "type": "number",
          "minimum": 0
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "fps": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "start",
          "end",
          "observations",
          "inferences"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "start": {
            "type": "number",
            "minimum": 0
          },
          "end": {
            "type": "number",
            "minimum": 0
          },
          "painting": {
            "type": [
              "string",
              "null"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "observations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "inferences": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "layers": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  }
}
